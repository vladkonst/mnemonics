# Server
SERVER_ADDR=:8080

# Database
DB_PATH=./mnemo.db

# Admin
ADMIN_TOKEN=change_me_in_production

# Payment Gateway (YooKassa)
PAYMENT_GATEWAY_URL=https://api.yookassa.ru/v2
PAYMENT_SHOP_ID=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=

# S3 Storage (MinIO or AWS S3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=mnemo
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PRESIGN_EXPIRY=15m

# Logging
LOG_LEVEL=debug
LOG_FORMAT=console

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=
